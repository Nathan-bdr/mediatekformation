{% extends "baseadmin.html.twig" %}

{% block body %}
    {% if estModification %}
        <h2>Modifier une playlist</h2>
    {% else %}
        <h2>Ajouter une playlist</h2>
    {% endif %}

    <form method="POST" class="mt-3">
        <div class="mb-3">
            <label for="name" class="form-label">Nom *</label>
            <input type="text" class="form-control" id="name" name="name"
                   value="{{ playlist.name|default('') }}" required>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea class="form-control" id="description" name="description">{{ playlist.description|default('') }}</textarea>
        </div>
        {% if estModification and formations|length > 0 %}
            <div class="mb-3">
                <label class="form-label">Formations rattachées</label>
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th scope="col">Titre</th>
                            <th scope="col">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for k in 0..formations|length-1 %}
                            <tr>
                                <td>{{ formations[k].title }}</td>
                                <td>{{ formations[k].publishedatstring }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
        <button type="submit" class="btn btn-info">
            {% if estModification %}
                Modifier
            {% else %}
                Ajouter
            {% endif %}
        </button>
        <a href="{{ path('admin.playlists') }}" class="btn btn-secondary">Annuler</a>
    </form>
{% endblock %}